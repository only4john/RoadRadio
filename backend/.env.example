# Laniakea Radio 后端环境变量配置
# 复制此文件为 .env 并填入真实密钥
# cp .env.example .env

# ==========================================
# 🔑 API 密钥（必填，使用真实的密钥）
# ==========================================
AMAP_API_KEY=your_amap_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
TAVILY_API_KEY=your_tavily_api_key_here

# ==========================================
# 🌐 DeepSeek 配置（可选，有默认值）
# ==========================================
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# 主力模型：生成电台剧本（需要高质量输出）
DEEPSEEK_MODEL=deepseek-chat
# 轻量模型：搜索判别 / 选 POI / 资料总结（省 token）
DEEPSEEK_LIGHT_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30.0

# ==========================================
# 🎙️ MiniMax 配置（可选，有默认值）
# ==========================================
MINIMAX_WS_URL=wss://api.minimax.chat/ws/v1/t2a_v2?GroupId=your_group_id

# ==========================================
# 🔍 Tavily Search 配置（可选，有默认值）
# ==========================================
# TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
# TAVILY_SEARCH_TIMEOUT=10.0

# ==========================================
# 📂 数据持久化（可选，默认 backend/data/ 目录）
# ==========================================
# DATA_DIR=./data
# POI_KNOWLEDGE_DB=./data/poi_knowledge.db
